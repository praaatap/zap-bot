# Shared
AWS_REGION=us-east-1

# Meeting processor lambda (index.mjs)
S3_BUCKET=zap-bot-meetings
API_CALLBACK_URL=http://localhost:3001/api/meetings/:id/ai-result
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=zap-bot
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
GROQ_API_KEY=your_groq_api_key
GROQ_EMBED_MODEL_ID=your_groq_embedding_model_id
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Embedding pipeline lambda (embedding-pipeline.mjs)
# Handler: embedding-pipeline.handler
# Trigger from Node webhook on transcription.ready

# Query lambda (query-agent.mjs)
# Handler: query-agent.handler
# Trigger from Node /api/chat via AWS Invoke

# Serverless agent API lambda (agent-api.mjs)
MEETING_BAAS_API_KEY=your_meeting_baas_api_key
MEETING_BAAS_BASE_URL=https://api.meetingbaas.com/v2
MEETING_BAAS_WEBHOOK_URL=https://your-api-domain/api/webhooks/meeting-baas

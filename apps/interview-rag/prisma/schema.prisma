// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Interview {
  id                String      @id @default(cuid())
  candidateId       String
  candidateName     String
  candidateEmail    String?
  position          String
  interviewDate     DateTime
  interviewer       String
  status            InterviewStatus @default(SCHEDULED)
  
  // Call metadata
  callDuration      Int?        // seconds
  recordingUrl      String?
  recordingMetadata Json?
  
  // Content
  transcript        String?     // full transcript
  summary           String?     // AI-generated summary
  candidateFeedback String?
  recruiterNotes    String?
  
  // Live tracking
  isLive            Boolean     @default(false)
  startTime         DateTime?
  endTime           DateTime?
  
  // Vector storage
  chunks            InterviewChunk[]
  embeddings        InterviewEmbedding[]
  
  // Relations
  conversationHistory ConversationMessage[]
  liveEvents        LiveEvent[]
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  @@index([candidateId])
  @@index([status])
  @@index([interviewDate])
  @@index([isLive])
}

model InterviewChunk {
  id                String      @id @default(cuid())
  interviewId       String
  interview         Interview   @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  
  content           String      // text chunk
  startTime         Float?      // timestamp in recording
  endTime           Float?
  speaker           String?     // who said it
  chunkIndex        Int
  
  // Pinecone references
  vectorId          String?     // Pinecone vector ID
  embeddingModel    String      @default("groq")
  
  createdAt         DateTime    @default(now())
  
  @@index([interviewId])
  @@index([vectorId])
}

model InterviewEmbedding {
  id                String      @id @default(cuid())
  interviewId       String
  interview         Interview   @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  
  chunkId           String
  vectorId          String      // Pinecone vector ID
  metadata          Json        // stores position, speaker, etc
  
  createdAt         DateTime    @default(now())
  
  @@index([interviewId])
  @@index([vectorId])
}

model ConversationMessage {
  id                String      @id @default(cuid())
  interviewId       String
  interview         Interview   @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  
  role              String      // "user", "assistant"
  content           String
  retrivedChunks    String[]    // array of chunk IDs used in RAG
  
  createdAt         DateTime    @default(now())
  
  @@index([interviewId])
}

model LiveEvent {
  id                String      @id @default(cuid())
  interviewId       String
  interview         Interview   @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  
  eventType         String      // "call_started", "transcript_received", "status_changed", etc
  data              Json        // event-specific data
  timestamp         DateTime    @default(now())
  
  @@index([interviewId])
  @@index([timestamp])
}

enum InterviewStatus {
  SCHEDULED
  RINGING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

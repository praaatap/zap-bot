# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Meeting BaaS
MEETING_BAAS_API_KEY=your_meeting_baas_api_key
MEETING_BAAS_WEBHOOK_URL=http://localhost:3001/api/webhooks/meeting-baas
MEETING_BAAS_MOCK=true

# AWS
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=zap-bot-meetings
AWS_LAMBDA_FUNCTION=zap-bot-meeting-processor
AWS_LAMBDA_EMBEDDING_FUNCTION=zap-bot-embedding-pipeline
AWS_LAMBDA_QUERY_FUNCTION=zap-bot-query-agent

# Pinecone and Bedrock
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=zap-bot
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# API server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Agent bridge (Node <-> Python)
PYTHON_AGENT_URL=http://localhost:8000
AGENT_BRIDGE_MODE=auto

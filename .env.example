# Appwrite Configuration
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_api_key_here

# Appwrite Database IDs
APPWRITE_DATABASE_ID=zapbot-main
APPWRITE_USERS_COLLECTION_ID=users
APPWRITE_MEETINGS_COLLECTION_ID=meetings
APPWRITE_INTEGRATIONS_COLLECTION_ID=user_integrations
APPWRITE_TRANSCRIPT_CHUNKS_COLLECTION_ID=transcript_chunks
APPWRITE_CHAT_MESSAGES_COLLECTION_ID=chat_messages
APPWRITE_SLACK_INSTALLATIONS_COLLECTION_ID=slack_installations
APPWRITE_STORAGE_BUCKET_ID=recordings
OBJECT_STORAGE_PROVIDER=appwrite

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
PYTHON_AGENT_URL=http://localhost:8000

# Third-party Services
NEXT_PUBLIC_PINECONE_INDEX=meeting-assistant
GROQ_API_KEY=your_groq_key_here
HUGGINGFACE_API_KEY=your_huggingface_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
OPENAI_API_KEY=your_openai_key_here

# Meeting Bot Services
MEETINGBAAS_API_KEY=your_meetingbaas_key_here
LIVEKIT_API_KEY=your_livekit_key_here
LIVEKIT_API_SECRET=your_livekit_secret_here

# Payment Processing
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Email Service
RESEND_API_KEY=your_resend_api_key_here

# Calendar Integration
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_secret_here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Holiday API (optional)
HOLIDAY_API_KEY=your_holiday_api_key_here

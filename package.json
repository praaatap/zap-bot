{
  "name": "zap-bot",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "test": "vitest run",
    "check-types": "next typegen && tsc --noEmit",
    "appwrite:setup": "node ./scripts/setup-appwrite-schema.mjs",
    "dev:api": "pnpm --filter api dev",
    "start:api": "pnpm --filter api start",
    "dev:all": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types:api": "pnpm --filter api check-types"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.705.0",
    "@aws-sdk/client-s3": "^3.705.0",
    "@aws-sdk/s3-request-presigner": "^3.705.0",
    "@clerk/nextjs": "^7.0.1",
    "@pinecone-database/pinecone": "^7.1.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@repo/shared": "workspace:*",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "@types/nodemailer": "^7.0.11",
    "appwrite": "^24.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.0",
    "googleapis": "^148.0.0",
    "groq-sdk": "^0.8.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.5",
    "node-appwrite": "^23.1.0",
    "nodemailer": "^8.0.1",
    "openai": "^6.27.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-calendar": "^5.1.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "stripe": "^20.4.1",
    "svix": "^1.86.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "postcss": "^8.5.8",
    "prettier": "^3.7.4",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.2.1",
    "turbo": "^2.8.13",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}